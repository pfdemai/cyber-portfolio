# Fichier d'exemple de configuration / Example configuration file
# Copier ce fichier en .env et remplir les valeurs
# Copy to .env and fill in values
#
# IMPORTANT: Ne jamais committer .env dans git / Never commit .env to git

# Utilisateur système / System user
PUID=1000
PGID=1000

# Fuseau horaire / Timezone
TIMEZONE=Europe/Paris

# IP du serveur sur le réseau lab / Server IP on lab network
SERVER_IP=10.0.0.10

# Chemin vers les médias / Path to media files
MEDIA_PATH=/mnt/media

# Chemin vers les téléchargements / Path to downloads folder
DOWNLOAD_PATH=/mnt/downloads
